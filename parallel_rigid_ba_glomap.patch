+// Function to ensure generic parallel rigidity in tracks (BA problem) via
+// viewgraph Note: Retiangulation functionality is not supported with generic
+// parallel rigidity check as new set of tracks are constructed and do not have
+// a new viewgraph object from which the new tracks are constructed.
+
+int TrackFilter::FilterTracksGenericParallelRigidityViaViewgraph(
+    ViewGraph& view_graph,
+    std::unordered_map<frame_t, Frame>& frames,
+    std::unordered_map<image_t, Image>& images,
+    std::unordered_map<track_t, Track>& tracks) {
+  int num_initial_tracks = tracks.size();
+
+  // Step 1: Recursively remove edges with tracks < 2 and tracks of length < 2
+  {
+    image_pair_t num_edges_modified, total_num_edges_modified = 0;
+    track_t num_tracks_modified, total_num_tracks_modified = 0;
+    std::vector<track_t> temp_track_list;
+
+    do {
+      num_edges_modified = 0;
+      num_tracks_modified = 0;
+
+      // Checking through edges
+      for (auto& [image_pair_idx, image_pair] : view_graph.image_pairs) {
+        if (!image_pair.is_valid) continue;
+
+        temp_track_list.clear();
+        for (const auto& tle : image_pair.track_list) {
+          if (tle.second) temp_track_list.push_back(tle.first);
+
+          if (temp_track_list.size() > 1)  // tracks per edge
+            break;
+        }
+
+        if (temp_track_list.size() < 2) {
+          // Remove the image pair from viewgraph
+          image_pair.is_valid = false;
+
+          if (temp_track_list.size() == 1) {
+            // Updating track
+            for (auto& [obs, image_pair_set] :
+                 tracks[temp_track_list[0]].obs_img_pair_map)
+              if (image_pair_set.find(image_pair.pair_id) !=
+                  image_pair_set.end()) {
+                image_pair_set.erase(image_pair.pair_id);
+                break;
+              }
+
+            // Updating image_pair
+            image_pair.track_list.at(temp_track_list[0]) = false;
+
+            num_edges_modified++;
+          }
+        }
+      }
+
+      total_num_edges_modified += num_edges_modified;
+
+      // Checking through tracks
+      temp_track_list.clear();
+      for (auto& [track_id, track] : tracks) {
+        if (track.observations.size() < 2) {
+          temp_track_list.push_back(track_id);  // tracks to be deleted
+
+          if (track.observations.size() == 1) {
+            // Remove tracks in edges
+            for (const auto& [obs, image_pair_set] : track.obs_img_pair_map)
+              for (const auto& image_pair_idx : image_pair_set)
+                view_graph.image_pairs.at(image_pair_idx)
+                    .track_list.erase(track_id);
+          }
+        }
+      }
+
+      for (auto& track_id : temp_track_list) tracks.erase(track_id);
+
+      num_tracks_modified = temp_track_list.size();
+      total_num_tracks_modified += num_tracks_modified;
+
+    } while (num_edges_modified != 0 || num_tracks_modified != 0);
+
+    LOG(INFO) << "Modified " << total_num_edges_modified << " edges and "
+              << total_num_tracks_modified
+              << " tracks (non-unique counts) in step 1 of PR in BA";
+
+    LOG(INFO) << "Tracks remaining after step 1 of PR in BA: " << tracks.size()
+              << " from initial: " << num_initial_tracks;
+  }
+
+  // Keeping only largest connected component
+  // This updates adjacency_list and images as well
+  if (view_graph.KeepLargestConnectedComponents(frames, images) == 0) {
+    LOG(ERROR) << "no connected components are found";
+    return 0;
+  }
+
+  // Step 2: Find edges in viewgraph whose scales are fixed
+  // Using union find algorithm over edges to get connected components
+
+  // Expected input: Tracks with length >=2 and edges with atleast 2 tracks
+  // We use union find to check which scales are connected via tracks
+  UnionFind<image_pair_t> uf;
+  uf.Clear();
+
+  std::unordered_set<image_pair_t> valid_image_pair_list;
+
+  const std::unordered_map<image_t, std::unordered_set<image_t>>&
+      adjacency_list = view_graph.GetAdjacencyList();
+
+  image_pair_t adj_img_pair_id;
+  std::vector<track_t> tr_list_image_pair, tr_list_adj_image_pair,
+      common_tr_list;
+
+  for (const auto& [image_pair_idx, image_pair] : view_graph.image_pairs) {
+    if (!image_pair.is_valid) continue;
+    valid_image_pair_list.insert(image_pair.pair_id);
+
+    tr_list_image_pair.clear();
+    for (const auto& [tr_idx, tr_status] : image_pair.track_list)
+      if (tr_status) tr_list_image_pair.push_back(tr_idx);
+
+    std::sort(tr_list_image_pair.begin(), tr_list_image_pair.end());
+
+    const auto& image_set_1 = adjacency_list.at(image_pair.image_id1);
+    const auto& image_set_2 = adjacency_list.at(image_pair.image_id2);
+
+    for (const auto& img : image_set_1) {
+      adj_img_pair_id = ImagePair::ImagePairToPairId(image_pair.image_id1, img);
+      if (view_graph.image_pairs.at(adj_img_pair_id).is_valid &&
+          uf.Find(image_pair.pair_id) != uf.Find(adj_img_pair_id)) {
+        tr_list_adj_image_pair.clear();
+        for (const auto& [tr_idx, tr_status] :
+             view_graph.image_pairs.at(adj_img_pair_id).track_list)
+          if (tr_status) tr_list_adj_image_pair.push_back(tr_idx);
+
+        std::sort(tr_list_adj_image_pair.begin(), tr_list_adj_image_pair.end());
+
+        // The two image pairs should have atleast 1 common track to share the
+        // scale
+        common_tr_list.clear();
+        std::set_intersection(
+            tr_list_image_pair.begin(),
+            tr_list_image_pair.end(),
+            tr_list_adj_image_pair.begin(),
+            tr_list_adj_image_pair.end(),
+            std::inserter(common_tr_list, common_tr_list.begin()));
+        if (common_tr_list.size())
+          uf.Union(image_pair.pair_id, adj_img_pair_id);
+      }
+    }
+
+    for (const auto& img : image_set_2) {
+      adj_img_pair_id = ImagePair::ImagePairToPairId(image_pair.image_id2, img);
+      if (view_graph.image_pairs.at(adj_img_pair_id).is_valid &&
+          uf.Find(image_pair.pair_id) != uf.Find(adj_img_pair_id)) {
+        tr_list_adj_image_pair.clear();
+        for (const auto& [tr_idx, tr_status] :
+             view_graph.image_pairs.at(adj_img_pair_id).track_list)
+          if (tr_status) tr_list_adj_image_pair.push_back(tr_idx);
+
+        std::sort(tr_list_adj_image_pair.begin(), tr_list_adj_image_pair.end());
+
+        // The two image pairs should have atleast 1 common track to share the
+        // scale
+        common_tr_list.clear();
+        std::set_intersection(
+            tr_list_image_pair.begin(),
+            tr_list_image_pair.end(),
+            tr_list_adj_image_pair.begin(),
+            tr_list_adj_image_pair.end(),
+            std::inserter(common_tr_list, common_tr_list.begin()));
+
+        if (common_tr_list.size())
+          uf.Union(image_pair.pair_id, adj_img_pair_id);
+      }
+    }
+  }
+
+  LOG(INFO) << "No. of valid image pairs: " << valid_image_pair_list.size()
+            << std::endl;
+
+  LOG(INFO) << "Obtained Union Find DS of edges in step 2 of PR in BA";
+
+  // Each component in union find data structure represents shared scales
+  // We only need to check if there are common atleast 2 tracks across two
+  // components
+
+  // Step 3: Merge components which have atleast two tracks in common
+
+  // Finding connected components of the edge graph
+  // Connected components of edge graph
+  std::unordered_map<image_pair_t, std::unordered_set<image_pair_t>>
+      cc_edge_graph;
+  // Track list in each connected component
+  std::unordered_map<image_pair_t, std::set<track_t>> cc_track_list;
+
+  for (const auto& img_pair_idx : valid_image_pair_list) {
+    auto root_val = uf.Find(img_pair_idx);
+    cc_edge_graph[root_val].insert(img_pair_idx);
+
+    for (const auto& [tr_idx, tr_status] :
+         view_graph.image_pairs.at(img_pair_idx).track_list)
+      if (tr_status) cc_track_list[root_val].insert(tr_idx);
+  }
+
+  // Extracting root values as in uf
+  std::vector<image_pair_t> root_values;
+  std::vector<track_t> ccs_common_tr_list;
+  root_values.reserve(cc_track_list.size());
+  for (auto& [root, track_set] : cc_track_list) root_values.push_back(root);
+
+  int prev_num_conn_comp, num_conn_comp = root_values.size();
+  bool merge_flag;
+
+  std::cout << "No. of connected components in the edge graph: "
+            << root_values.size() << std::endl;
+
+  do {
+    prev_num_conn_comp = num_conn_comp;
+    merge_flag = false;
+    int i = 0, j = 0;
+    for (i = 0; i < root_values.size() - 1; i++) {
+      for (j = i + 1; j < root_values.size(); j++) {
+        ccs_common_tr_list.clear();
+        std::set_intersection(
+            cc_track_list[root_values[i]].begin(),
+            cc_track_list[root_values[i]].end(),
+            cc_track_list[root_values[j]].begin(),
+            cc_track_list[root_values[j]].end(),
+            std::inserter(ccs_common_tr_list, ccs_common_tr_list.begin()));
+
+        // Merge if there are two or more common tracks
+        if (ccs_common_tr_list.size() > 1) {
+          merge_flag = true;
+          break;
+        }
+      }
+
+      if (merge_flag) break;
+    }
+
+    if (merge_flag) {
+      cc_edge_graph[root_values[i]].insert(
+          cc_edge_graph[root_values[j]].begin(),
+          cc_edge_graph[root_values[j]].end());
+      cc_edge_graph.erase(root_values[j]);
+
+      cc_track_list[root_values[i]].insert(
+          cc_track_list[root_values[j]].begin(),
+          cc_track_list[root_values[j]].end());
+      cc_track_list.erase(root_values[j]);
+
+      root_values.erase(std::next(root_values.begin(), j));
+
+      num_conn_comp = root_values.size();
+
+      LOG(INFO) << "i: " << i << ", j: " << j << " merged!\n";
+    }
+
+    LOG(INFO) << "Prev Conn Comp: " << prev_num_conn_comp
+              << ", Curr Conn Comp: " << num_conn_comp << std::endl;
+  } while (prev_num_conn_comp != num_conn_comp);
+
+  LOG(INFO) << "Obtained largest connected component of Union Find DS in step "
+               "3 of PR in BA\n";
+
+  // Only retain largest cc of edge graph
+  // Update edges to be false
+  // Update tracks to remove edge idx
+
+  uint size_max_cc = 0, idx_max_cc = 0;
+  for (int i = 0; i < root_values.size(); i++) {
+    if (size_max_cc < cc_edge_graph[root_values[i]].size()) {
+      size_max_cc = cc_edge_graph[root_values[i]].size();
+      idx_max_cc = i;
+    }
+  }
+
+  LOG(INFO) << "No. of edges in max connected component of edge graph: "
+            << size_max_cc << std::endl;
+
+  for (const auto& root_val : root_values) {
+    if (root_val == root_values[idx_max_cc]) continue;
+
+    for (const auto& image_pair_idx : cc_edge_graph[root_val])
+      view_graph.image_pairs.at(image_pair_idx).is_valid = false;
+  }
+
+  TrackObsCleanup(view_graph, tracks);
+
+  image_t num_imgs = view_graph.KeepLargestConnectedComponents(frames, images);
+  if (num_imgs == 0) {
+    LOG(ERROR) << "no connected components are found";
+    return 0;
+  } else {
+    LOG(INFO)
+        << num_imgs
+        << " images are within the largest connected component of viewgraph";
+  }
+
+  LOG(INFO) << "Tracks before PR filtering: " << num_initial_tracks
+            << ", after PR filtering: " << tracks.size() << std::endl;
+
+  return tracks.size();
+}

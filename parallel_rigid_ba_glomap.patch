+void RemoveEmptyTracks(std::unordered_map<track_t, Track>& tracks) {
+  size_t tracks_init_size = tracks.size();
+  std::vector<track_t> temp_track_list;  // tracks to be deleted
+  int counter = 0;
+  for (auto& [track_id, track] : tracks)
+    if (track.observations.size() == 0) {
+      temp_track_list.push_back(track_id);
+      counter++;
+    }
+
+  for (auto& track_id : temp_track_list) tracks.erase(track_id);
+
+  LOG(INFO) << "Deleting " << counter << " / " << tracks_init_size
+            << " tracks with zero observations";
+}
+
+// Function to remove isolated observations after filtering of tracks
+void TrackObsCleanup(const ViewGraph& view_graph,
+                     std::unordered_map<track_t, Track>& tracks) {
+  std::vector<image_pair_t> remove_image_pair_indices, remove_obs_indices;
+  std::vector<track_t>
+      remove_track_idx;  // Tracks to be removed if no. of observations < 2
+  for (auto& [track_id, track] : tracks) {
+    // Removing non-existant image_pair indices
+    remove_obs_indices.clear();
+    std::vector<Observation> observations_new;
+    for (auto& [obs, image_pair_set] : track.obs_img_pair_map) {
+      remove_image_pair_indices.clear();
+      for (const auto& image_pair_idx : image_pair_set)
+        if (!view_graph.image_pairs.at(image_pair_idx).is_valid ||
+            !view_graph.image_pairs.at(image_pair_idx)
+                 .track_list.at(track.track_id))
+          remove_image_pair_indices.push_back(image_pair_idx);
+
+      for (auto& rem_idx : remove_image_pair_indices)
+        image_pair_set.erase(rem_idx);
+
+      // Remove isolated observations
+      if (image_pair_set.size() == 0) {
+        remove_obs_indices.push_back(obs);
+      } else {
+        image_t image_id = obs >> 32;
+        feature_t feature_id = obs & 0xFFFFFFFF;
+        observations_new.emplace_back(image_id, feature_id);
+      }
+    }
+
+    // Remove observations and obs_img_pair_map
+    for (auto& rem_idx : remove_obs_indices)
+      track.obs_img_pair_map.erase(rem_idx);
+
+    if (observations_new.size() < 2) remove_track_idx.push_back(track_id);
+
+    track.observations = observations_new;
+  }
+
+  int counter = 0;
+  for (const auto& tr_idx : remove_track_idx) {
+    tracks.erase(tr_idx);
+    counter++;
+  }
+
+  LOG(INFO) << "Track cleaning up done by deleting " << counter << " tracks!";
+  LOG(INFO) << "Tracks remaining: " << tracks.size();
+}
